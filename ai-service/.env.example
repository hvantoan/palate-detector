# AI Service Configuration
# Copy this file to .env and modify as needed
# All settings can be overridden via environment variables

# ===========================================
# Server Configuration
# ===========================================

# Host address to bind the server
# HOST=0.0.0.0

# Port to bind the server (default: 8100 to avoid common dev ports)
# PORT=8100

# Enable auto-reload for development
# RELOAD=false


# ===========================================
# Model Configuration
# ===========================================

# Directory containing model files
# MODELS_DIR=models

# Path to YOLO plate detection model
# YOLO_MODEL_PATH=models/yolo_plate_detection.pt

# Path to OCR model directory
# OCR_MODEL_PATH=models/ocr


# ===========================================
# Detection Thresholds
# ===========================================

# Minimum confidence score for plate detection (0.0 - 1.0)
# CONFIDENCE_THRESHOLD=0.5

# Non-maximum suppression threshold for overlapping detections (0.0 - 1.0)
# NMS_THRESHOLD=0.4

# Minimum area (pixels) for valid plate detection
# MIN_PLATE_AREA=500


# ===========================================
# Upload Configuration
# ===========================================

# Maximum file upload size in bytes (default: 10MB)
# MAX_UPLOAD_SIZE=10485760

# Allowed MIME types for image uploads (comma-separated)
# ALLOWED_IMAGE_TYPES=["image/jpeg", "image/png", "image/webp"]


# ===========================================
# Logging Configuration
# ===========================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO


# ===========================================
# CORS Configuration
# ===========================================

# Allowed CORS origins (comma-separated list)
# CORS_ORIGINS=["tauri://localhost", "http://localhost"]