# EditorConfig - Consistent coding style across all workspaces
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Rust (src-tauri/)
[*.rs]
indent_style = space
indent_size = 4

# Rust Cargo files
[Cargo.toml]
indent_style = space
indent_size = 4

# TypeScript/JavaScript/JSON (src/)
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

# Vite config
[vite.config.ts]
indent_style = space
indent_size = 2

# TypeScript config
[tsconfig.json]
indent_style = space
indent_size = 2

# HTML (src/)
[*.html]
indent_style = space
indent_size = 2

# CSS/SCSS
[*.{css,scss,sass}]
indent_style = space
indent_size = 2

# Python (ai-service/)
[*.py]
indent_style = space
indent_size = 4

# Python project config
[pyproject.toml]
indent_style = space
indent_size = 4

# YAML files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

# Tauri configuration
[tauri.conf.json]
indent_style = space
indent_size = 2